{
  "appId": "com.mnemo.app",
  "appName": "Mnemo",
  "webDir": "../frontend/out",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#6366f1"
    },
    "Keyboard": {
      "resize": "none"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#09090b",
      "showSpinner": false
    }
  }
}
